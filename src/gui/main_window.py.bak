#!/usr/bin/env python3
"""
CDR Analysis Tool - Main Window
Main application window with all analysis features
"""

import tkinter as tk
from tkinter import ttk, filedialog, messagebox, scrolledtext
import csv
import threading
import sys
import os
from typing import Any, Dict, List, Optional, Tuple

# Add parent directory to path for imports
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))

from database.db_manager import DatabaseManager
from database.csv_importer import CSVImporter


class CDRAnalysisTool:
    """Main CDR Analysis and Investigation Tool"""
    
    def __init__(self, root):
        """
        Initialize the CDR Analysis Tool
        
        Args:
            root: Tkinter root window
        """
        self.root = root
        self.root.title("CDR Analysis & Investigation - February 2025 - Licensed to Manoj Dube 9819194961")
        self.root.geometry("1400x800")
        self.root.resizable(True, True)

        try:
            style = ttk.Style()
            style.theme_use("clam")
        except Exception:
            pass

        project_root = os.path.dirname(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
        data_dir = os.path.join(project_root, "data")
        os.makedirs(data_dir, exist_ok=True)
        self.db_path = os.path.join(data_dir, "cdr_database.db")
        self.db_manager = DatabaseManager(self.db_path)

        self._sort_reverse = {}

        self._search_page = 0
        self._search_total = 0
        self._search_last_filters = {}

        self._db_page = 0
        self._db_total = 0

        self._is_importing = False
        
        self.setup_ui()
    
    def setup_ui(self):
        """Setup the user interface"""
        # Menu bar
        menubar = tk.Menu(self.root)
        self.root.config(menu=menubar)
        
        file_menu = tk.Menu(menubar, tearoff=0)
        menubar.add_cascade(label="File", menu=file_menu)
        file_menu.add_command(label="Upload CSV", command=self.upload_csv)
        file_menu.add_command(label="Change Database", command=self.change_database)
        file_menu.add_command(label="Refresh", command=self.refresh_ui)
        file_menu.add_separator()
        file_menu.add_command(label="Exit", command=self.root.quit)

        self.main_container = ttk.Frame(self.root)
        self.main_container.pack(fill=tk.BOTH, expand=True)

        self.status_var = tk.StringVar(value=f"DB: {self.db_path}")
        status_bar = ttk.Label(self.main_container, textvariable=self.status_var, anchor=tk.W)
        status_bar.pack(side=tk.BOTTOM, fill=tk.X, padx=5, pady=2)
        
        # Notebook (tabs)
        self.notebook = ttk.Notebook(self.main_container)
        self.notebook.pack(fill=tk.BOTH, expand=True, padx=5, pady=5)
        
        # Create tabs
        self.home_frame = ttk.Frame(self.notebook)
        self.search_frame = ttk.Frame(self.notebook)
        self.normal_cdr_frame = ttk.Frame(self.notebook)
        self.tower_cdr_frame = ttk.Frame(self.notebook)
        self.groups_frame = ttk.Frame(self.notebook)
        self.reports_frame = ttk.Frame(self.notebook)
        self.database_frame = ttk.Frame(self.notebook)
        
        self.notebook.add(self.home_frame, text="Home")
        self.notebook.add(self.search_frame, text="Search")
        self.notebook.add(self.normal_cdr_frame, text="Investigation")
        self.notebook.add(self.tower_cdr_frame, text="Tower/CGI")
        self.notebook.add(self.groups_frame, text="Groups")
        self.notebook.add(self.reports_frame, text="Reports")
        self.notebook.add(self.database_frame, text="Database")
        
        self.create_home_tab()
        self.create_search_tab()
        self.create_normal_cdr_tab()
        self.create_tower_cdr_tab()
        self.create_groups_tab()
        self.create_reports_tab()
        self.create_database_tab()

        self.refresh_ui()
    
    def create_home_tab(self):
        """Create home tab"""
        frame = ttk.Frame(self.home_frame, padding="20")
        frame.pack(fill=tk.BOTH, expand=True)
        
        title = ttk.Label(frame, text="CDR Analysis & Investigation Tool", 
                         font=("Helvetica", 18, "bold"))
        title.pack(pady=20)
        
        # Quick actions
        actions_frame = ttk.LabelFrame(frame, text="Quick Actions", padding="15")
        actions_frame.pack(fill=tk.X, pady=10)
        
        ttk.Button(actions_frame, text="Upload CSV File", 
                  command=self.upload_csv, width=20).pack(side=tk.LEFT, padx=5, pady=10)
        ttk.Button(actions_frame, text="View Database", 
                  command=lambda: self.notebook.select(self.database_frame), 
                  width=20).pack(side=tk.LEFT, padx=5, pady=10)
        ttk.Button(actions_frame, text="Search Records", 
                  command=lambda: self.notebook.select(self.search_frame), 
                  width=20).pack(side=tk.LEFT, padx=5, pady=10)
        
        # Information
        info_text = scrolledtext.ScrolledText(frame, height=20, width=100, wrap=tk.WORD)
        info_text.pack(fill=tk.BOTH, expand=True, pady=10)
        
        info = """
Welcome to CDR Analysis & Investigation Tool

This application provides comprehensive analysis of Call Data Records (CDR) for investigative purposes.

Key Features:
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

📊 Data Management:
   • Upload CSV files directly to SQLite database
   • Support for Normal CDR and Tower CDR data
   • Automatic data parsing and validation
   • Export data to CSV format

🔍 Search & Filter:
   • Search by A Party (Caller) and B Party (Receiver)
   • Filter by date, time, IMEI, IMSI
   • Advanced search with multiple criteria
   • Quick result visualization

👥 Group Analysis:
   • Analyze common and uncommon numbers
   • Track number combinations (A+B)
   • IMEI-based grouping and analysis
   • Call type and service type statistics

📈 Reports & Analytics:
   • Max call duration analysis
   • Most used IMEI reports
   • Call statistics and patterns
   • Location-based analysis (CGI data)

🗄️ Database Operations:
   • View all records with pagination
   • Clear database functionality
   • Export filtered data
   • Database statistics

Quick Start Guide:
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

1. Click "Upload CSV File" or go to File → Upload CSV
2. Select your CDR CSV file
3. Wait for the upload to complete
4. Use the "Search" tab to find specific records
5. Use "Groups" tab to analyze call patterns
6. Generate reports from the "Reports" tab

Supported CSV Format:
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

The CSV should contain columns like:
• Target No, Call Type, TOC
• B Party No, LRN No, LRN TSP-LSA
• Date, Time, Dur(s)
• First CGI, Last CGI
• IMEI, IMSI, Service Type
• And other telecom metadata

The tool will automatically detect the header row and import data accordingly.

For any issues or support, please contact the system administrator.
        """
        
        info_text.insert(1.0, info)
        info_text.config(state=tk.DISABLED)
    
    def create_search_tab(self):
        """Create search tab"""
        frame = ttk.Frame(self.search_frame, padding="10")
        frame.pack(fill=tk.BOTH, expand=True)

        self.search_call_type_var = tk.StringVar()
        self.search_service_type_var = tk.StringVar()
        self.search_limit_var = tk.StringVar(value="500")
        self.search_page_var = tk.StringVar(value="Page 1")
        self.search_total_var = tk.StringVar(value="0 results")

        # Search controls
        search_frame = ttk.LabelFrame(frame, text="Search Filters", padding="10")
        search_frame.pack(fill=tk.X, pady=5)

        ttk.Label(search_frame, text="A Party:").grid(row=0, column=0, padx=5, pady=5, sticky=tk.W)
        self.search_a_party = ttk.Entry(search_frame, width=18)
        self.search_a_party.grid(row=0, column=1, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="B Party:").grid(row=0, column=2, padx=5, pady=5, sticky=tk.W)
        self.search_b_party = ttk.Entry(search_frame, width=18)
        self.search_b_party.grid(row=0, column=3, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Call Type:").grid(row=0, column=4, padx=5, pady=5, sticky=tk.W)
        self.search_call_type = ttk.Combobox(
            search_frame,
            width=16,
            textvariable=self.search_call_type_var,
            values=[""],
            state="readonly",
        )
        self.search_call_type.grid(row=0, column=5, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Service Type:").grid(row=0, column=6, padx=5, pady=5, sticky=tk.W)
        self.search_service_type = ttk.Combobox(
            search_frame,
            width=16,
            textvariable=self.search_service_type_var,
            values=[""],
            state="readonly",
        )
        self.search_service_type.grid(row=0, column=7, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Date From:").grid(row=1, column=0, padx=5, pady=5, sticky=tk.W)
        self.search_date_from = ttk.Entry(search_frame, width=18)
        self.search_date_from.grid(row=1, column=1, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Date To:").grid(row=1, column=2, padx=5, pady=5, sticky=tk.W)
        self.search_date_to = ttk.Entry(search_frame, width=18)
        self.search_date_to.grid(row=1, column=3, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Time From:").grid(row=1, column=4, padx=5, pady=5, sticky=tk.W)
        self.search_time_from = ttk.Entry(search_frame, width=16)
        self.search_time_from.grid(row=1, column=5, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Time To:").grid(row=1, column=6, padx=5, pady=5, sticky=tk.W)
        self.search_time_to = ttk.Entry(search_frame, width=16)
        self.search_time_to.grid(row=1, column=7, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="IMEI:").grid(row=2, column=0, padx=5, pady=5, sticky=tk.W)
        self.search_imei = ttk.Entry(search_frame, width=18)
        self.search_imei.grid(row=2, column=1, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="IMSI:").grid(row=2, column=2, padx=5, pady=5, sticky=tk.W)
        self.search_imsi = ttk.Entry(search_frame, width=18)
        self.search_imsi.grid(row=2, column=3, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Dur Min:").grid(row=2, column=4, padx=5, pady=5, sticky=tk.W)
        self.search_dur_min = ttk.Entry(search_frame, width=16)
        self.search_dur_min.grid(row=2, column=5, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Dur Max:").grid(row=2, column=6, padx=5, pady=5, sticky=tk.W)
        self.search_dur_max = ttk.Entry(search_frame, width=16)
        self.search_dur_max.grid(row=2, column=7, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="CGI:").grid(row=3, column=0, padx=5, pady=5, sticky=tk.W)
        self.search_cgi = ttk.Entry(search_frame, width=18)
        self.search_cgi.grid(row=3, column=1, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, text="Limit:").grid(row=3, column=2, padx=5, pady=5, sticky=tk.W)
        self.search_limit = ttk.Entry(search_frame, width=8, textvariable=self.search_limit_var)
        self.search_limit.grid(row=3, column=3, padx=5, pady=5, sticky=tk.W)

        ttk.Label(search_frame, textvariable=self.search_page_var).grid(row=3, column=4, padx=5, pady=5, sticky=tk.W)
        ttk.Label(search_frame, textvariable=self.search_total_var).grid(row=3, column=5, padx=5, pady=5, sticky=tk.W)

        button_frame = ttk.Frame(search_frame)
        button_frame.grid(row=4, column=0, columnspan=8, pady=10, sticky=tk.W)
        ttk.Button(button_frame, text="Search", command=self.search_records).pack(side=tk.LEFT, padx=5)
        ttk.Button(button_frame, text="Clear", command=self.clear_search).pack(side=tk.LEFT, padx=5)
        ttk.Button(button_frame, text="Export Results", command=self.export_search_results).pack(side=tk.LEFT, padx=5)
        ttk.Button(button_frame, text="Prev", command=self.search_prev_page).pack(side=tk.LEFT, padx=5)
        ttk.Button(button_frame, text="Next", command=self.search_next_page).pack(side=tk.LEFT, padx=5)

        paned = ttk.PanedWindow(frame, orient=tk.HORIZONTAL)
        paned.pack(fill=tk.BOTH, expand=True, pady=5)

        # Results table
        table_frame = ttk.LabelFrame(paned, text="Search Results", padding="10")
        details_frame = ttk.LabelFrame(paned, text="Record Details", padding="10")
        paned.add(table_frame, weight=4)
        paned.add(details_frame, weight=2)

        vsb = ttk.Scrollbar(table_frame, orient=tk.VERTICAL)
        hsb = ttk.Scrollbar(table_frame, orient=tk.HORIZONTAL)
        self.search_tree = ttk.Treeview(
            table_frame,
            columns=(
                "A_PARTY",
                "B_PARTY",
                "DATE",
                "TIME",
                "DURATION",
                "CALL_TYPE",
                "SERVICE_TYPE",
                "IMEI",
                "IMSI",
                "FIRST_CGI",
                "LAST_CGI",
            ),
            yscrollcommand=vsb.set,
            xscrollcommand=hsb.set,
        )
        vsb.config(command=self.search_tree.yview)
        hsb.config(command=self.search_tree.xview)

        self.search_tree.column("#0", width=80, minwidth=80)
        self.search_tree.column("A_PARTY", width=140, minwidth=120)
        self.search_tree.column("B_PARTY", width=140, minwidth=120)
        self.search_tree.column("DATE", width=100, minwidth=100)
        self.search_tree.column("TIME", width=90, minwidth=90)
        self.search_tree.column("DURATION", width=90, minwidth=80)
        self.search_tree.column("CALL_TYPE", width=120, minwidth=100)
        self.search_tree.column("SERVICE_TYPE", width=140, minwidth=120)
        self.search_tree.column("IMEI", width=160, minwidth=140)
        self.search_tree.column("IMSI", width=160, minwidth=140)
        self.search_tree.column("FIRST_CGI", width=140, minwidth=120)
        self.search_tree.column("LAST_CGI", width=140, minwidth=120)

        self._set_tree_heading(self.search_tree, "#0", "ID")
        self._set_tree_heading(self.search_tree, "A_PARTY", "A Party")
        self._set_tree_heading(self.search_tree, "B_PARTY", "B Party")
        self._set_tree_heading(self.search_tree, "DATE", "Date")
        self._set_tree_heading(self.search_tree, "TIME", "Time")
        self._set_tree_heading(self.search_tree, "DURATION", "Dur(s)")
        self._set_tree_heading(self.search_tree, "CALL_TYPE", "Call Type")
        self._set_tree_heading(self.search_tree, "SERVICE_TYPE", "Service Type")
        self._set_tree_heading(self.search_tree, "IMEI", "IMEI")
        self._set_tree_heading(self.search_tree, "IMSI", "IMSI")
        self._set_tree_heading(self.search_tree, "FIRST_CGI", "First CGI")
        self._set_tree_heading(self.search_tree, "LAST_CGI", "Last CGI")

        self.search_tree.grid(row=0, column=0, sticky=tk.NSEW)
        vsb.grid(row=0, column=1, sticky=tk.NS)
        hsb.grid(row=1, column=0, sticky=tk.EW)
        table_frame.columnconfigure(0, weight=1)
        table_frame.rowconfigure(0, weight=1)

        self.search_tree.bind("<<TreeviewSelect>>", self.on_search_select)
        self.search_tree.bind("<Button-3>", lambda e: self.show_record_context_menu(e, self.search_tree))
        self.search_tree.bind("<Control-Button-1>", lambda e: self.show_record_context_menu(e, self.search_tree))

        details_vsb = ttk.Scrollbar(details_frame, orient=tk.VERTICAL)
        self.search_details_tree = ttk.Treeview(
            details_frame,
            columns=("VALUE",),
            show="tree headings",
            yscrollcommand=details_vsb.set,
        )
        details_vsb.config(command=self.search_details_tree.yview)

        self.search_details_tree.column("#0", width=150, minwidth=120)
        self.search_details_tree.column("VALUE", width=360, minwidth=200)
        self.search_details_tree.heading("#0", text="Field", anchor=tk.W)
        self.search_details_tree.heading("VALUE", text="Value", anchor=tk.W)

        self.search_details_tree.grid(row=0, column=0, sticky=tk.NSEW)
        details_vsb.grid(row=0, column=1, sticky=tk.NS)
        details_frame.columnconfigure(0, weight=1)
        details_frame.rowconfigure(0, weight=1)
    
    def create_normal_cdr_tab(self):
        """Create Investigation tab"""
        frame = ttk.Frame(self.normal_cdr_frame, padding="10")
        frame.pack(fill=tk.BOTH, expand=True)
        
        title = ttk.Label(frame, text="Investigation & Link Analysis", font=("Helvetica", 14, "bold"))
        title.pack(pady=10)

        nb = ttk.Notebook(frame)
        self.inv_notebook = nb
        nb.pack(fill=tk.BOTH, expand=True)

        contacts_frame = ttk.Frame(nb, padding="10")
        mutual_frame = ttk.Frame(nb, padding="10")
        link_frame = ttk.Frame(nb, padding="10")
        timeline_frame = ttk.Frame(nb, padding="10")
        imei_frame = ttk.Frame(nb, padding="10")

        self.inv_tab_contacts = contacts_frame
        self.inv_tab_mutual = mutual_frame
        self.inv_tab_link = link_frame
        self.inv_tab_timeline = timeline_frame
        self.inv_tab_imei = imei_frame

        nb.add(contacts_frame, text="Top Contacts")
        nb.add(mutual_frame, text="Mutual Contacts")
        nb.add(link_frame, text="Direct Link")
        nb.add(timeline_frame, text="Timeline")
        nb.add(imei_frame, text="IMEI / IMSI")

        # Top contacts
        controls = ttk.LabelFrame(contacts_frame, text="Inputs", padding="10")
        controls.pack(fill=tk.X, pady=5)

        ttk.Label(controls, text="Number:").grid(row=0, column=0, padx=5, pady=5, sticky=tk.W)
        self.tc_number = ttk.Entry(controls, width=22)
        self.tc_number.grid(row=0, column=1, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Date From:").grid(row=0, column=2, padx=5, pady=5, sticky=tk.W)
        self.tc_date_from = ttk.Entry(controls, width=14)
        self.tc_date_from.grid(row=0, column=3, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Date To:").grid(row=0, column=4, padx=5, pady=5, sticky=tk.W)
        self.tc_date_to = ttk.Entry(controls, width=14)
        self.tc_date_to.grid(row=0, column=5, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Limit:").grid(row=0, column=6, padx=5, pady=5, sticky=tk.W)
        self.tc_limit = ttk.Entry(controls, width=8)
        self.tc_limit.insert(0, "50")
        self.tc_limit.grid(row=0, column=7, padx=5, pady=5, sticky=tk.W)

        btns = ttk.Frame(controls)
        btns.grid(row=1, column=0, columnspan=8, sticky=tk.W, pady=5)
        ttk.Button(btns, text="Run", command=self.run_top_contacts).pack(side=tk.LEFT, padx=5)
        ttk.Button(btns, text="Export", command=lambda: self.export_treeview_to_csv(self.top_contacts_tree)).pack(side=tk.LEFT, padx=5)

        results = ttk.LabelFrame(contacts_frame, text="Results", padding="10")
        results.pack(fill=tk.BOTH, expand=True, pady=5)

        self.top_contacts_tree = self._create_results_tree(
            parent=results,
            columns=("CONTACT", "CALLS", "TOTAL_DURATION", "FIRST_DT", "LAST_DT"),
            headings={
                "#0": "Rank",
                "CONTACT": "Contact",
                "CALLS": "Calls",
                "TOTAL_DURATION": "Total Dur(s)",
                "FIRST_DT": "First Seen",
                "LAST_DT": "Last Seen",
            },
            widths={
                "#0": 60,
                "CONTACT": 160,
                "CALLS": 90,
                "TOTAL_DURATION": 110,
                "FIRST_DT": 170,
                "LAST_DT": 170,
            },
        )

        # Mutual contacts (two numbers)
        controls = ttk.LabelFrame(mutual_frame, text="Inputs", padding="10")
        controls.pack(fill=tk.X, pady=5)

        ttk.Label(controls, text="Number A:").grid(row=0, column=0, padx=5, pady=5, sticky=tk.W)
        self.mc_number_a = ttk.Entry(controls, width=22)
        self.mc_number_a.grid(row=0, column=1, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Number B:").grid(row=0, column=2, padx=5, pady=5, sticky=tk.W)
        self.mc_number_b = ttk.Entry(controls, width=22)
        self.mc_number_b.grid(row=0, column=3, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Date From:").grid(row=0, column=4, padx=5, pady=5, sticky=tk.W)
        self.mc_date_from = ttk.Entry(controls, width=14)
        self.mc_date_from.grid(row=0, column=5, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Date To:").grid(row=0, column=6, padx=5, pady=5, sticky=tk.W)
        self.mc_date_to = ttk.Entry(controls, width=14)
        self.mc_date_to.grid(row=0, column=7, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Limit:").grid(row=0, column=8, padx=5, pady=5, sticky=tk.W)
        self.mc_limit = ttk.Entry(controls, width=8)
        self.mc_limit.insert(0, "100")
        self.mc_limit.grid(row=0, column=9, padx=5, pady=5, sticky=tk.W)

        btns = ttk.Frame(controls)
        btns.grid(row=1, column=0, columnspan=10, sticky=tk.W, pady=5)
        ttk.Button(btns, text="Run", command=self.run_mutual_contacts).pack(side=tk.LEFT, padx=5)
