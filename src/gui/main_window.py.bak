        self.db_details_tree.heading("VALUE", text="Value", anchor=tk.W)

        self.db_details_tree.grid(row=0, column=0, sticky=tk.NSEW)
        details_vsb.grid(row=0, column=1, sticky=tk.NS)
        details_frame.columnconfigure(0, weight=1)
        details_frame.rowconfigure(0, weight=1)
    
    # Implementation methods
    
    def set_status(self, message: str):
        if hasattr(self, "status_var"):
            self.status_var.set(message)

    def refresh_ui(self):
        try:
            total = self.db_manager.count_records_advanced({})
            self._db_total = total
            self.set_status(f"DB: {self.db_path} | Records: {total}")
        except Exception:
            self.set_status(f"DB: {self.db_path}")

        try:
            call_types = [""] + sorted(self.db_manager.get_distinct_values("call_type"))
            service_types = [""] + sorted(self.db_manager.get_distinct_values("service_type"))

            if hasattr(self, "search_call_type"):
                self.search_call_type["values"] = call_types
            if hasattr(self, "search_service_type"):
                self.search_service_type["values"] = service_types
        except Exception:
            pass

        if hasattr(self, "db_total_var"):
            self.db_total_var.set(f"{self._db_total} records")

    def _set_tree_heading(self, tree: ttk.Treeview, col: str, text: str):
        tree.heading(col, text=text, anchor=tk.W, command=lambda c=col, t=tree: self._sort_tree(t, c))

    @staticmethod
    def _coerce_sort_value(value: Any) -> Tuple[int, Any]:
        if value is None:
            return (1, "")
        s = str(value).strip()
        if not s:
            return (1, "")
        try:
            return (0, int(s))
        except Exception:
            pass
        try:
            return (0, float(s))
        except Exception:
            pass
        return (0, s.lower())

    def _sort_tree(self, tree: ttk.Treeview, col: str):
        reverse = bool(self._sort_reverse.get((tree, col), False))

        items: List[Tuple[Tuple[int, Any], str]] = []
        for iid in tree.get_children(""):
            if col == "#0":
                value = tree.item(iid, "text")
            else:
                value = tree.set(iid, col)
            items.append((self._coerce_sort_value(value), iid))

        items.sort(key=lambda x: x[0], reverse=reverse)
        for index, (_, iid) in enumerate(items):
            tree.move(iid, "", index)

        self._sort_reverse[(tree, col)] = not reverse

    def _create_results_tree(
        self,
        parent: ttk.Frame,
        columns: Tuple[str, ...],
        headings: Dict[str, str],
        widths: Dict[str, int],
    ) -> ttk.Treeview:
        vsb = ttk.Scrollbar(parent, orient=tk.VERTICAL)
        hsb = ttk.Scrollbar(parent, orient=tk.HORIZONTAL)

        tree = ttk.Treeview(parent, columns=columns, yscrollcommand=vsb.set, xscrollcommand=hsb.set)
        vsb.config(command=tree.yview)
        hsb.config(command=tree.xview)

        tree.column("#0", width=widths.get("#0", 80), minwidth=60)
        tree.heading("#0", text=headings.get("#0", "ID"), anchor=tk.W)

        for col in columns:
            tree.column(col, width=widths.get(col, 120), minwidth=max(80, widths.get(col, 120) // 2))
            self._set_tree_heading(tree, col, headings.get(col, col))

        tree.grid(row=0, column=0, sticky=tk.NSEW)
        vsb.grid(row=0, column=1, sticky=tk.NS)
        hsb.grid(row=1, column=0, sticky=tk.EW)
        parent.columnconfigure(0, weight=1)
        parent.rowconfigure(0, weight=1)
        return tree

    def export_treeview_to_csv(self, tree: ttk.Treeview):
        items = tree.get_children()
        if not items:
            messagebox.showwarning("No Data", "No data to export")
            return

        file_path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=[("CSV files", "*.csv"), ("All files", "*.*")],
        )
        if not file_path:
            return

        try:
            columns = list(tree["columns"])
            headers = [tree.heading("#0").get("text", "ID")] + [tree.heading(c).get("text", c) for c in columns]

            with open(file_path, "w", newline="", encoding="utf-8") as csvfile:
                writer = csv.writer(csvfile)
                writer.writerow(headers)
                for iid in items:
                    row_id = tree.item(iid).get("text", "")
                    values = tree.item(iid).get("values", [])
                    writer.writerow([row_id] + list(values))

            self.set_status(f"Exported {len(items)} rows → {file_path}")
        except Exception as e:
            messagebox.showerror("Error", f"Export error: {str(e)}")

    @staticmethod
    def _safe_int(value: str, default: int) -> int:
        try:
            return int(str(value).strip())
        except Exception:
            return default

    def _populate_details(self, record_id: int, details_tree: ttk.Treeview):
        for item in details_tree.get_children():
            details_tree.delete(item)

        details = self.db_manager.get_record_details(record_id)
        if not details:
            return

        preferred = ["id"] + list(getattr(self.db_manager, "_INSERT_COLUMNS", []))
        keys = [k for k in preferred if k in details] + [k for k in details.keys() if k not in preferred]

        for key in keys:
            value = details.get(key)
            details_tree.insert("", tk.END, text=str(key), values=(("" if value is None else str(value)),))

    def _get_row_data_from_tree(self, tree: ttk.Treeview, event: Optional[tk.Event] = None) -> Optional[Dict[str, str]]:
        iid = None
        if event is not None:
            iid = tree.identify_row(event.y)
        if not iid:
            selected = tree.selection()
            iid = selected[0] if selected else None
        if not iid:
            return None

        try:
            tree.selection_set(iid)
            tree.focus(iid)
        except Exception:
            pass

        cols = list(tree["columns"])
        values = list(tree.item(iid, "values") or [])

        data: Dict[str, str] = {"ID": str(tree.item(iid, "text") or iid)}
        for idx, col in enumerate(cols):
            data[col] = str(values[idx]) if idx < len(values) and values[idx] is not None else ""
        return data

    def show_record_context_menu(self, event: tk.Event, tree: ttk.Treeview):
        data = self._get_row_data_from_tree(tree, event=event)
        if not data:
            return

        a_party = data.get("A_PARTY", "").strip()
        b_party = data.get("B_PARTY", "").strip()
        imei = data.get("IMEI", "").strip()
        first_cgi = data.get("FIRST_CGI", "").strip()
        last_cgi = data.get("LAST_CGI", "").strip()

        menu = tk.Menu(self.root, tearoff=0)

        if a_party:
            menu.add_command(label="Investigate A Party (Top Contacts)", command=lambda: self._open_investigation_top_contacts(a_party))
            menu.add_command(label="Investigate A Party (Timeline)", command=lambda: self._open_investigation_timeline(a_party))
            menu.add_command(label="A Party → IMEI", command=lambda: self._open_investigation_number_to_imei(a_party))
            menu.add_separator()

        if b_party:
            menu.add_command(label="Investigate B Party (Top Contacts)", command=lambda: self._open_investigation_top_contacts(b_party))
            menu.add_command(label="Investigate B Party (Timeline)", command=lambda: self._open_investigation_timeline(b_party))
            menu.add_command(label="B Party → IMEI", command=lambda: self._open_investigation_number_to_imei(b_party))
            menu.add_separator()

        if imei:
            menu.add_command(label="IMEI → Numbers", command=lambda: self._open_investigation_imei_to_numbers(imei))
            menu.add_separator()

        if a_party:
            menu.add_command(label="Tower/CGI for A Party", command=lambda: self._open_tower_for_number(a_party))
        if b_party:
            menu.add_command(label="Tower/CGI for B Party", command=lambda: self._open_tower_for_number(b_party))

        if first_cgi:
            menu.add_command(label="CGI → Numbers (First CGI)", command=lambda: self._open_numbers_on_cgi(first_cgi))
        if last_cgi:
            menu.add_command(label="CGI → Numbers (Last CGI)", command=lambda: self._open_numbers_on_cgi(last_cgi))

        try:
            menu.tk_popup(event.x_root, event.y_root)
        finally:
            try:
                menu.grab_release()
            except Exception:
                pass

    def _open_investigation_top_contacts(self, number: str):
        self.notebook.select(self.normal_cdr_frame)
        if hasattr(self, "inv_notebook"):
            if hasattr(self, "inv_tab_contacts"):
                self.inv_notebook.select(self.inv_tab_contacts)
            else:
                self.inv_notebook.select(0)
        self.tc_number.delete(0, tk.END)
        self.tc_number.insert(0, number)
        self.run_top_contacts()

    def _open_investigation_timeline(self, number: str):
        self.notebook.select(self.normal_cdr_frame)
        if hasattr(self, "inv_notebook"):
            if hasattr(self, "inv_tab_timeline"):
                self.inv_notebook.select(self.inv_tab_timeline)
            else:
                self.inv_notebook.select(2)
        self.tl_number.delete(0, tk.END)
        self.tl_number.insert(0, number)
        self.run_timeline()

    def _open_investigation_imei_to_numbers(self, imei: str):
        self.notebook.select(self.normal_cdr_frame)
        if hasattr(self, "inv_notebook"):
            if hasattr(self, "inv_tab_imei"):
                self.inv_notebook.select(self.inv_tab_imei)
            else:
                self.inv_notebook.select(3)
        if hasattr(self, "inv_imei_notebook"):
            if hasattr(self, "inv_imei_tab_i2n"):
                self.inv_imei_notebook.select(self.inv_imei_tab_i2n)
            else:
                self.inv_imei_notebook.select(0)
        self.i2n_imei.delete(0, tk.END)
        self.i2n_imei.insert(0, imei)
        self.run_numbers_by_imei()

    def _open_investigation_number_to_imei(self, number: str):
        self.notebook.select(self.normal_cdr_frame)
        if hasattr(self, "inv_notebook"):
            if hasattr(self, "inv_tab_imei"):
                self.inv_notebook.select(self.inv_tab_imei)
            else:
                self.inv_notebook.select(3)
        if hasattr(self, "inv_imei_notebook"):
            if hasattr(self, "inv_imei_tab_n2i"):
                self.inv_imei_notebook.select(self.inv_imei_tab_n2i)
            else:
                self.inv_imei_notebook.select(1)
        self.n2i_number.delete(0, tk.END)
        self.n2i_number.insert(0, number)
        self.run_imeis_by_number()

    def _open_tower_for_number(self, number: str):
        self.notebook.select(self.tower_cdr_frame)
        if hasattr(self, "tower_notebook"):
            if hasattr(self, "tower_tab_top"):
                self.tower_notebook.select(self.tower_tab_top)
            else:
                self.tower_notebook.select(0)
        self.cgi_number.delete(0, tk.END)
        self.cgi_number.insert(0, number)
        self.run_top_cgi("first_cgi")
        self.run_top_cgi("last_cgi")

    def _open_numbers_on_cgi(self, cgi_value: str):
        self.notebook.select(self.tower_cdr_frame)
        if hasattr(self, "tower_notebook"):
            if hasattr(self, "tower_tab_numbers"):
                self.tower_notebook.select(self.tower_tab_numbers)
            else:
                self.tower_notebook.select(1)
        self.cgi_value.delete(0, tk.END)
        self.cgi_value.insert(0, cgi_value)
        self.run_numbers_on_cgi()

    def upload_csv(self):
        """Upload CSV file to database"""
        if self._is_importing:
            messagebox.showwarning("Import in progress", "An import is already running. Please wait.")
            return

        file_path = filedialog.askopenfilename(
            title="Select CSV File",
            filetypes=[("CSV files", "*.csv"), ("All files", "*.*")]
        )
        if not file_path:
            return

        self._is_importing = True
        self.set_status(f"Importing: {os.path.basename(file_path)}")

        def progress_cb(progress, count):
            self.root.after(0, lambda: self.set_status(f"Importing... {progress}% | Inserted: {count}"))

        def worker():
            try:
                importer = CSVImporter(self.db_manager)
                success, message, _count = importer.import_csv(file_path, progress_callback=progress_cb)

                def done():
                    self._is_importing = False
                    if success:
                        messagebox.showinfo("Success", message)
                        self.refresh_ui()
                        self.view_all_records()
                    else:
                        messagebox.showerror("Error", message)
                        self.refresh_ui()

                self.root.after(0, done)
            except Exception as e:
                def failed():
                    self._is_importing = False
                    messagebox.showerror("Error", f"Error uploading file: {str(e)}")
                    self.refresh_ui()

                self.root.after(0, failed)

        threading.Thread(target=worker, daemon=True).start()
    
    def search_records(self):
        """Search records with filters"""
        self._search_page = 0
        self._search_last_filters = self._get_search_filters()
        self._run_search_page()

    def _get_search_filters(self) -> Dict[str, Any]:
        filters: Dict[str, Any] = {}

        a_party = self.search_a_party.get().strip()
        b_party = self.search_b_party.get().strip()
        imei = self.search_imei.get().strip()
        imsi = self.search_imsi.get().strip()
        date_from = self.search_date_from.get().strip()
        date_to = self.search_date_to.get().strip()
        time_from = self.search_time_from.get().strip()
        time_to = self.search_time_to.get().strip()
        cgi = self.search_cgi.get().strip()
        call_type = self.search_call_type_var.get().strip() if hasattr(self, "search_call_type_var") else ""
        service_type = self.search_service_type_var.get().strip() if hasattr(self, "search_service_type_var") else ""

        if a_party:
            filters["a_party"] = a_party
        if b_party:
            filters["b_party"] = b_party
        if imei:
            filters["imei"] = imei
        if imsi:
            filters["imsi"] = imsi
        if date_from:
            filters["date_from"] = date_from
        if date_to:
            filters["date_to"] = date_to
        if time_from:
            filters["time_from"] = time_from
        if time_to:
            filters["time_to"] = time_to
        if cgi:
            filters["cgi"] = cgi
        if call_type:
            filters["call_type"] = call_type
        if service_type:
            filters["service_type"] = service_type

        dur_min = self.search_dur_min.get().strip()
        dur_max = self.search_dur_max.get().strip()
        if dur_min:
            filters["duration_min"] = self._safe_int(dur_min, 0)
        if dur_max:
            filters["duration_max"] = self._safe_int(dur_max, 0)

        return filters

    def _run_search_page(self):
        try:
            limit = max(1, self._safe_int(self.search_limit_var.get(), 500))
            offset = self._search_page * limit

            total = self.db_manager.count_records_advanced(self._search_last_filters)
            self._search_total = total

            rows = self.db_manager.search_records_advanced(self._search_last_filters, limit=limit, offset=offset)

            for item in self.search_tree.get_children():
                self.search_tree.delete(item)

            for row in rows:
                dt = row[3] or ""
                date_str = dt[:10] if dt else ""
                time_str = dt[11:19] if dt else ""
                self.search_tree.insert(
                    "",
                    tk.END,
                    iid=str(row[0]),
                    text=str(row[0]),
                    values=(
                        row[1] or "",
                        row[2] or "",
                        date_str,
                        time_str,
                        row[4] if row[4] is not None else "",
                        row[5] or "",
                        row[6] or "",
                        row[7] or "",
                        row[8] or "",
                        row[9] or "",
                        row[10] or "",
                    ),
                )

            max_pages = max(1, (total + limit - 1) // limit)
            self.search_page_var.set(f"Page {self._search_page + 1} / {max_pages}")
            self.search_total_var.set(f"{total} results")
            self.set_status(f"Search: {len(rows)} shown | Total: {total}")
        except Exception as e:
            messagebox.showerror("Error", f"Search error: {str(e)}")

    def search_prev_page(self):
        if self._search_page <= 0:
            return
        self._search_page -= 1
        self._run_search_page()

    def search_next_page(self):
        limit = max(1, self._safe_int(self.search_limit_var.get(), 500))
        if (self._search_page + 1) * limit >= self._search_total:
            return
        self._search_page += 1
        self._run_search_page()
    
    def clear_search(self):
        """Clear search fields and results"""
        self.search_a_party.delete(0, tk.END)
        self.search_b_party.delete(0, tk.END)
        self.search_date_from.delete(0, tk.END)
        self.search_date_to.delete(0, tk.END)
        self.search_time_from.delete(0, tk.END)
        self.search_time_to.delete(0, tk.END)
        self.search_imei.delete(0, tk.END)
        self.search_imsi.delete(0, tk.END)
        self.search_dur_min.delete(0, tk.END)
        self.search_dur_max.delete(0, tk.END)
        self.search_cgi.delete(0, tk.END)
        if hasattr(self, "search_call_type_var"):
            self.search_call_type_var.set("")
        if hasattr(self, "search_service_type_var"):
            self.search_service_type_var.set("")

        self._search_page = 0
        self._search_total = 0
        self._search_last_filters = {}
        self.search_page_var.set("Page 1")
        self.search_total_var.set("0 results")

        for item in self.search_tree.get_children():
            self.search_tree.delete(item)
        for item in self.search_details_tree.get_children():
            self.search_details_tree.delete(item)
        self.set_status("Search cleared")
    
    def export_search_results(self):
        """Export current search view to CSV"""
        self.export_treeview_to_csv(self.search_tree)

    def on_search_select(self, _event=None):
        selected = self.search_tree.selection()
        if not selected:
            return
        try:
            record_id = int(selected[0])
        except Exception:
            return
        self._populate_details(record_id, self.search_details_tree)
    
    def analyze_group(self, group_type):
        """Analyze groups by type"""
        try:
            # Clear existing results
            for item in self.groups_tree.get_children():
                self.groups_tree.delete(item)
            
            field_map = {
                "a_party": "target_no",
                "b_party": "b_party_no",
                "imei": "imei",
                "imsi": "imsi",
                "call_type": "call_type",
                "service_type": "service_type",
                "toc": "toc",
                "roam_nw": "roam_nw",
                "first_cgi": "first_cgi",
                "last_cgi": "last_cgi",
            }

            group_by = field_map.get(group_type)
            if not group_by:
                return

            results = self.db_manager.get_group_statistics(group_by)

            for i, (value, count) in enumerate(results, start=1):
                self.groups_tree.insert("", tk.END, text=str(i), values=(str(value)[:80] if value else "N/A", count))

            self.set_status(f"Groups ({group_by}): {len(results)} rows")
        except Exception as e:
            messagebox.showerror("Error", f"Analysis error: {str(e)}")
    
    def get_analytics(self, analytics_type):
        """Backward-compatible wrapper for legacy analytics buttons."""
        try:
            self.notebook.select(self.reports_frame)
        except Exception:
            pass

        if analytics_type == "max_duration":
            self.run_top_durations()
        elif analytics_type == "max_imei":
            self.run_top_imeis()
        elif analytics_type == "total_records":
            self.run_summary()
        elif analytics_type == "call_stats":
            self.run_distribution("call_type")
    
    def view_all_records(self):
        """View all database records"""
        self._db_page = 0
        self._run_db_page()

    def _run_db_page(self):
        try:
            limit = max(1, self._safe_int(self.db_limit_var.get(), 500))
            offset = self._db_page * limit

            total = self.db_manager.count_records_advanced({})
            self._db_total = total

            rows = self.db_manager.search_records_advanced({}, limit=limit, offset=offset)

            for item in self.db_tree.get_children():
                self.db_tree.delete(item)

            for row in rows:
                dt = row[3] or ""
                date_str = dt[:10] if dt else ""
                time_str = dt[11:19] if dt else ""
                self.db_tree.insert(
                    "",
                    tk.END,
                    iid=str(row[0]),
                    text=str(row[0]),
                    values=(
                        row[1] or "",
                        row[2] or "",
                        date_str,
                        time_str,
                        row[4] if row[4] is not None else "",
                        row[5] or "",
                        row[6] or "",
                        row[7] or "",
                        row[8] or "",
                        row[9] or "",
                        row[10] or "",
                    ),
                )

            max_pages = max(1, (total + limit - 1) // limit)
            self.db_page_var.set(f"Page {self._db_page + 1} / {max_pages}")
            self.db_total_var.set(f"{total} records")
            self.set_status(f"Database: {len(rows)} shown | Total: {total}")
        except Exception as e:
            messagebox.showerror("Error", f"Error loading records: {str(e)}")

    def db_prev_page(self):
        if self._db_page <= 0:
            return
        self._db_page -= 1
        self._run_db_page()

    def db_next_page(self):
        limit = max(1, self._safe_int(self.db_limit_var.get(), 500))
        if (self._db_page + 1) * limit >= self._db_total:
            return
        self._db_page += 1
        self._run_db_page()

    def on_db_select(self, _event=None):
        selected = self.db_tree.selection()
        if not selected:
            return
        try:
            record_id = int(selected[0])
        except Exception:
            return
        self._populate_details(record_id, self.db_details_tree)
    
    def clear_database(self):
        """Clear all database records"""
        if messagebox.askyesno("Confirm", 
                              "Are you sure you want to clear all database records?\n\nThis action cannot be undone!"):
            try:
                if self.db_manager.clear_all_records():
                    messagebox.showinfo("Success", "Database cleared successfully!")
                    self.refresh_ui()
                    self.view_all_records()
                else:
                    messagebox.showerror("Error", "Failed to clear database")
            except Exception as e:
                messagebox.showerror("Error", f"Error clearing database: {str(e)}")
    
    def export_to_csv(self):
        """Export database to CSV"""
        file_path = filedialog.asksaveasfilename(
            defaultextension=".csv",
            filetypes=[("CSV files", "*.csv"), ("All files", "*.*")]
        )
        if not file_path:
            return
        
        try:
            columns, rows = self.db_manager.export_to_list()
            
            with open(file_path, 'w', newline='', encoding='utf-8') as csvfile:
                writer = csv.writer(csvfile)
                writer.writerow(columns)
                writer.writerows(rows)
            
            messagebox.showinfo("Success", f"Exported {len(rows)} records to {file_path}")
        except Exception as e:
            messagebox.showerror("Error", f"Export error: {str(e)}")

    def run_summary(self):
        stats = self.db_manager.get_summary_stats()
        for item in self.summary_tree.get_children():
            self.summary_tree.delete(item)

        if not stats:
            self.set_status("Summary: no data")
            return

        for key in [
            "total_records",
            "unique_a_party",
            "unique_b_party",
            "unique_imei",
            "unique_imsi",
            "min_datetime",
            "max_datetime",
        ]:
            if key not in stats:
                continue
            self.summary_tree.insert("", tk.END, text=key, values=(stats.get(key, ""),))

        self.set_status("Summary refreshed")

    def run_top_durations(self):
        number = self.rp_dur_number.get().strip() or None
        date_from = self.rp_dur_date_from.get().strip() or None
        date_to = self.rp_dur_date_to.get().strip() or None
        limit = max(1, self._safe_int(self.rp_dur_limit.get(), 50))

        rows = self.db_manager.get_top_duration_records(limit=limit, number=number, date_from=date_from, date_to=date_to)
        for item in self.top_duration_tree.get_children():
            self.top_duration_tree.delete(item)

        for i, row in enumerate(rows, start=1):
            self.top_duration_tree.insert(
                "",
                tk.END,
                text=str(i),
                values=(
                    row[1] or "",
                    row[2] or "",
                    row[3] or "",
                    row[4] if row[4] is not None else "",
                    row[5] or "",
                    row[6] or "",
                    row[7] or "",
                    row[8] or "",
                ),
            )

        self.set_status(f"Top Durations: {len(rows)} rows")

    def run_top_imeis(self):
        date_from = self.rp_imei_date_from.get().strip() or None
        date_to = self.rp_imei_date_to.get().strip() or None
        limit = max(1, self._safe_int(self.rp_imei_limit.get(), 50))

        rows = self.db_manager.get_top_imeis(limit=limit, date_from=date_from, date_to=date_to)
        for item in self.top_imei_tree.get_children():
            self.top_imei_tree.delete(item)

        for i, row in enumerate(rows, start=1):
            self.top_imei_tree.insert("", tk.END, text=str(i), values=(row[0] or "", row[1] or 0, row[2] or "", row[3] or ""))

        self.set_status(f"Top IMEI: {len(rows)} rows")

    def run_distribution(self, column: str):
        column = (column or "").strip()
        if column == "call_type":
            date_from = self.rp_ct_date_from.get().strip() or None
            date_to = self.rp_ct_date_to.get().strip() or None
            limit = max(1, self._safe_int(self.rp_ct_limit.get(), 200))
            tree = self.call_type_tree
        elif column == "service_type":
            date_from = self.rp_st_date_from.get().strip() or None
            date_to = self.rp_st_date_to.get().strip() or None
            limit = max(1, self._safe_int(self.rp_st_limit.get(), 200))
            tree = self.service_type_tree
        else:
            return

        rows = self.db_manager.get_distribution(column=column, limit=limit, date_from=date_from, date_to=date_to)
        for item in tree.get_children():
            tree.delete(item)

        for i, row in enumerate(rows, start=1):
            tree.insert("", tk.END, text=str(i), values=(row[0] or "", row[1] or 0))

        self.set_status(f"{column} distribution: {len(rows)} rows")

    def run_top_contacts(self):
        number = self.tc_number.get().strip()
        if not number:
            messagebox.showwarning("Missing input", "Please enter a number.")
            return
        date_from = self.tc_date_from.get().strip() or None
        date_to = self.tc_date_to.get().strip() or None
        limit = max(1, self._safe_int(self.tc_limit.get(), 50))

        rows = self.db_manager.get_top_contacts(number, date_from=date_from, date_to=date_to, limit=limit)
        for item in self.top_contacts_tree.get_children():
            self.top_contacts_tree.delete(item)
        for i, row in enumerate(rows, start=1):
            self.top_contacts_tree.insert(
                "",
                tk.END,
                text=str(i),
                values=(row[0] or "", row[1] or 0, row[2] or 0, row[3] or "", row[4] or ""),
            )
        self.set_status(f"Top Contacts: {len(rows)} rows")

    def run_mutual_contacts(self):
        number_a = self.mc_number_a.get().strip()
        number_b = self.mc_number_b.get().strip()
        if not number_a or not number_b:
            messagebox.showwarning("Missing input", "Please enter both Number A and Number B.")
            return
        date_from = self.mc_date_from.get().strip() or None
        date_to = self.mc_date_to.get().strip() or None
        limit = max(1, self._safe_int(self.mc_limit.get(), 100))

        rows = self.db_manager.get_mutual_contacts_two_numbers(
            number_a=number_a,
            number_b=number_b,
            date_from=date_from,
            date_to=date_to,
            limit=limit,
        )
        for item in self.mutual_contacts_tree.get_children():
            self.mutual_contacts_tree.delete(item)
        for i, row in enumerate(rows, start=1):
            self.mutual_contacts_tree.insert("", tk.END, text=str(i), values=row)
        self.set_status(f"Mutual Contacts: {len(rows)} rows")

    def run_direct_link(self):
        number_a = self.dl_number_a.get().strip()
        number_b = self.dl_number_b.get().strip()
        if not number_a or not number_b:
            messagebox.showwarning("Missing input", "Please enter both Number A and Number B.")
            return

        date_from = self.dl_date_from.get().strip() or None
        date_to = self.dl_date_to.get().strip() or None
        limit = max(1, self._safe_int(self.dl_limit.get(), 500))

        summary = self.db_manager.get_direct_link_summary(number_a, number_b, date_from=date_from, date_to=date_to)
        calls = self.db_manager.get_calls_between_numbers(number_a, number_b, date_from=date_from, date_to=date_to, limit=limit)
        types = self.db_manager.get_call_type_distribution_for_pair(number_a, number_b, date_from=date_from, date_to=date_to, limit=100)

        for item in self.direct_link_summary_tree.get_children():
            self.direct_link_summary_tree.delete(item)

        if summary:
            for key in [
                "total_calls",
                "total_duration",
                "a_to_b_calls",
                "a_to_b_duration",
                "b_to_a_calls",
                "b_to_a_duration",
                "first_dt",
                "last_dt",
            ]:
                self.direct_link_summary_tree.insert("", tk.END, text=key, values=(summary.get(key, ""),))

        for item in self.direct_link_calls_tree.get_children():
            self.direct_link_calls_tree.delete(item)

        for row in calls:
            record_id = row[0]
            dt = row[1] or ""
            a_party = row[2] or ""
            b_party = row[3] or ""
            duration = row[4] if row[4] is not None else ""
            call_type = row[5] or ""
            service_type = row[6] or ""
            imei = row[7] or ""
            imsi = row[8] or ""
            first_cgi = row[9] or ""
            last_cgi = row[10] or ""

            direction = "A→B" if (a_party == number_a and b_party == number_b) else "B→A"

            self.direct_link_calls_tree.insert(
                "",
                tk.END,
                iid=str(record_id),
                text=str(record_id),
                values=(dt, direction, duration, call_type, service_type, imei, imsi, first_cgi, last_cgi),
            )

        for item in self.direct_link_types_tree.get_children():
            self.direct_link_types_tree.delete(item)

        for i, row in enumerate(types, start=1):
            self.direct_link_types_tree.insert("", tk.END, text=str(i), values=(row[0] or "", row[1] or 0))

        self.set_status(f"Direct Link: {len(calls)} calls | {len(types)} call types")

    def run_timeline(self):
        number = self.tl_number.get().strip()
        if not number:
            messagebox.showwarning("Missing input", "Please enter a number.")
            return
        date_from = self.tl_date_from.get().strip() or None
        date_to = self.tl_date_to.get().strip() or None
        group_by = self.tl_group_var.get().strip() or "day"
        limit = max(1, self._safe_int(self.tl_limit.get(), 400))

        rows = self.db_manager.get_number_timeline(
            number=number,
            date_from=date_from,
            date_to=date_to,
            group_by=group_by,
            limit=limit,
        )
        for item in self.timeline_tree.get_children():
            self.timeline_tree.delete(item)
        for i, row in enumerate(rows, start=1):
            self.timeline_tree.insert("", tk.END, text=str(i), values=(row[0] or "", row[1] or 0, row[2] or 0))
        self.set_status(f"Timeline: {len(rows)} rows")

    def run_numbers_by_imei(self):
