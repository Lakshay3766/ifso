        vsb.config(command=self.db_tree.yview)
        hsb.config(command=self.db_tree.xview)

        self.db_tree.column("#0", width=80, minwidth=80)
        self.db_tree.column("A_PARTY", width=140, minwidth=120)
        self.db_tree.column("B_PARTY", width=140, minwidth=120)
        self.db_tree.column("DATE", width=100, minwidth=100)
        self.db_tree.column("TIME", width=90, minwidth=90)
        self.db_tree.column("DURATION", width=90, minwidth=80)
        self.db_tree.column("CALL_TYPE", width=120, minwidth=100)
        self.db_tree.column("SERVICE_TYPE", width=140, minwidth=120)
        self.db_tree.column("IMEI", width=160, minwidth=140)
        self.db_tree.column("IMSI", width=160, minwidth=140)
        self.db_tree.column("FIRST_CGI", width=140, minwidth=120)
        self.db_tree.column("LAST_CGI", width=140, minwidth=120)

        self._set_tree_heading(self.db_tree, "#0", "ID")
        self._set_tree_heading(self.db_tree, "A_PARTY", "A Party")
        self._set_tree_heading(self.db_tree, "B_PARTY", "B Party")
        self._set_tree_heading(self.db_tree, "DATE", "Date")
        self._set_tree_heading(self.db_tree, "TIME", "Time")
        self._set_tree_heading(self.db_tree, "DURATION", "Dur(s)")
        self._set_tree_heading(self.db_tree, "CALL_TYPE", "Call Type")
        self._set_tree_heading(self.db_tree, "SERVICE_TYPE", "Service Type")
        self._set_tree_heading(self.db_tree, "IMEI", "IMEI")
