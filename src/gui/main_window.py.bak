    def create_tower_cdr_tab(self):
        """Create Tower/CGI tab"""
        frame = ttk.Frame(self.tower_cdr_frame, padding="10")
        frame.pack(fill=tk.BOTH, expand=True)
        
        title = ttk.Label(frame, text="Tower / CGI Analysis", font=("Helvetica", 14, "bold"))
        title.pack(pady=10)

        nb = ttk.Notebook(frame)
        self.tower_notebook = nb
        nb.pack(fill=tk.BOTH, expand=True)

        top_cgi_frame = ttk.Frame(nb, padding="10")
        cgi_numbers_frame = ttk.Frame(nb, padding="10")
        self.tower_tab_top = top_cgi_frame
        self.tower_tab_numbers = cgi_numbers_frame
        nb.add(top_cgi_frame, text="Top CGI")
        nb.add(cgi_numbers_frame, text="CGI → Numbers")

        # Top CGI
        controls = ttk.LabelFrame(top_cgi_frame, text="Inputs", padding="10")
        controls.pack(fill=tk.X, pady=5)

        ttk.Label(controls, text="Number (optional):").grid(row=0, column=0, padx=5, pady=5, sticky=tk.W)
        self.cgi_number = ttk.Entry(controls, width=22)
        self.cgi_number.grid(row=0, column=1, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Date From:").grid(row=0, column=2, padx=5, pady=5, sticky=tk.W)
        self.cgi_date_from = ttk.Entry(controls, width=14)
        self.cgi_date_from.grid(row=0, column=3, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Date To:").grid(row=0, column=4, padx=5, pady=5, sticky=tk.W)
        self.cgi_date_to = ttk.Entry(controls, width=14)
        self.cgi_date_to.grid(row=0, column=5, padx=5, pady=5, sticky=tk.W)

        ttk.Label(controls, text="Limit:").grid(row=0, column=6, padx=5, pady=5, sticky=tk.W)
        self.cgi_limit = ttk.Entry(controls, width=8)
        self.cgi_limit.insert(0, "100")
        self.cgi_limit.grid(row=0, column=7, padx=5, pady=5, sticky=tk.W)

        btns = ttk.Frame(controls)
        btns.grid(row=1, column=0, columnspan=8, sticky=tk.W, pady=5)
        ttk.Button(btns, text="Top First CGI", command=lambda: self.run_top_cgi("first_cgi")).pack(side=tk.LEFT, padx=5)
        ttk.Button(btns, text="Top Last CGI", command=lambda: self.run_top_cgi("last_cgi")).pack(side=tk.LEFT, padx=5)
        ttk.Button(btns, text="Export First", command=lambda: self.export_treeview_to_csv(self.first_cgi_tree)).pack(side=tk.LEFT, padx=5)
        ttk.Button(btns, text="Export Last", command=lambda: self.export_treeview_to_csv(self.last_cgi_tree)).pack(side=tk.LEFT, padx=5)

        paned = ttk.PanedWindow(top_cgi_frame, orient=tk.HORIZONTAL)
        paned.pack(fill=tk.BOTH, expand=True, pady=5)

        first_frame = ttk.LabelFrame(paned, text="First CGI", padding="10")
        last_frame = ttk.LabelFrame(paned, text="Last CGI", padding="10")
        paned.add(first_frame, weight=1)
        paned.add(last_frame, weight=1)

        self.first_cgi_tree = self._create_results_tree(
            parent=first_frame,
            columns=("CGI", "COUNT"),
            headings={"#0": "Rank", "CGI": "CGI", "COUNT": "Count"},
            widths={"#0": 60, "CGI": 260, "COUNT": 100},
        )
        self.last_cgi_tree = self._create_results_tree(
            parent=last_frame,
            columns=("CGI", "COUNT"),
            headings={"#0": "Rank", "CGI": "CGI", "COUNT": "Count"},
            widths={"#0": 60, "CGI": 260, "COUNT": 100},
        )

        # CGI -> Numbers
        controls = ttk.LabelFrame(cgi_numbers_frame, text="Inputs", padding="10")
        controls.pack(fill=tk.X, pady=5)
        ttk.Label(controls, text="CGI contains:").grid(row=0, column=0, padx=5, pady=5, sticky=tk.W)
        self.cgi_value = ttk.Entry(controls, width=30)
        self.cgi_value.grid(row=0, column=1, padx=5, pady=5, sticky=tk.W)
        ttk.Label(controls, text="Limit:").grid(row=0, column=2, padx=5, pady=5, sticky=tk.W)
        self.cgi_numbers_limit = ttk.Entry(controls, width=8)
        self.cgi_numbers_limit.insert(0, "200")
        self.cgi_numbers_limit.grid(row=0, column=3, padx=5, pady=5, sticky=tk.W)
        ttk.Button(controls, text="Run", command=self.run_numbers_on_cgi).grid(row=0, column=4, padx=5, pady=5, sticky=tk.W)
        ttk.Button(controls, text="Export", command=lambda: self.export_treeview_to_csv(self.cgi_numbers_tree)).grid(row=0, column=5, padx=5, pady=5, sticky=tk.W)

        results = ttk.LabelFrame(cgi_numbers_frame, text="Results", padding="10")
        results.pack(fill=tk.BOTH, expand=True, pady=5)

        self.cgi_numbers_tree = self._create_results_tree(
            parent=results,
            columns=("NUMBER", "COUNT"),
            headings={"#0": "Rank", "NUMBER": "Number", "COUNT": "Count"},
            widths={"#0": 60, "NUMBER": 220, "COUNT": 100},
        )
    
    def create_groups_tab(self):
        """Create groups analysis tab"""
        frame = ttk.Frame(self.groups_frame, padding="10")
        frame.pack(fill=tk.BOTH, expand=True)
        
        title = ttk.Label(frame, text="Groups Analysis", font=("Helvetica", 14, "bold"))
        title.pack(pady=10)
        
        # Group analysis options
        options = ttk.LabelFrame(frame, text="Group By", padding="10")
        options.pack(fill=tk.X, pady=10)

        buttons = [
            ("A Party", "a_party"),
            ("B Party", "b_party"),
            ("IMEI", "imei"),
            ("IMSI", "imsi"),
            ("Call Type", "call_type"),
            ("Service Type", "service_type"),
            ("TOC", "toc"),
            ("Roam NW", "roam_nw"),
            ("First CGI", "first_cgi"),
            ("Last CGI", "last_cgi"),
        ]

        for idx, (label, key) in enumerate(buttons):
            ttk.Button(options, text=label, command=lambda k=key: self.analyze_group(k)).grid(
                row=idx // 5,
                column=idx % 5,
                padx=5,
                pady=5,
                sticky=tk.W,
            )

        ttk.Button(options, text="Export", command=lambda: self.export_treeview_to_csv(self.groups_tree)).grid(
            row=2,
            column=0,
            padx=5,
            pady=5,
            sticky=tk.W,
        )
        
        # Results
        results_frame = ttk.LabelFrame(frame, text="Group Results", padding="10")
        results_frame.pack(fill=tk.BOTH, expand=True, pady=10)
        
        vsb = ttk.Scrollbar(results_frame, orient=tk.VERTICAL)
        hsb = ttk.Scrollbar(results_frame, orient=tk.HORIZONTAL)
        
        self.groups_tree = ttk.Treeview(results_frame, columns=("VALUE", "COUNT"), 
                                        yscrollcommand=vsb.set, xscrollcommand=hsb.set)
        vsb.config(command=self.groups_tree.yview)
        hsb.config(command=self.groups_tree.xview)
        
        self.groups_tree.column("#0", width=200, minwidth=200)
        self.groups_tree.column("VALUE", width=400, minwidth=300)
        self.groups_tree.column("COUNT", width=100, minwidth=100)
        
        self._set_tree_heading(self.groups_tree, "#0", "Rank")
        self._set_tree_heading(self.groups_tree, "VALUE", "Value")
        self._set_tree_heading(self.groups_tree, "COUNT", "Count")
        
        self.groups_tree.grid(row=0, column=0, sticky=tk.NSEW)
        vsb.grid(row=0, column=1, sticky=tk.NS)
        hsb.grid(row=1, column=0, sticky=tk.EW)
        results_frame.columnconfigure(0, weight=1)
        results_frame.rowconfigure(0, weight=1)
    
    def create_reports_tab(self):
        """Create reports and analytics tab"""
        frame = ttk.Frame(self.reports_frame, padding="10")
        frame.pack(fill=tk.BOTH, expand=True)
        
        title = ttk.Label(frame, text="Reports & Analytics", font=("Helvetica", 14, "bold"))
        title.pack(pady=10)

        nb = ttk.Notebook(frame)
