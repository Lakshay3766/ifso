    def run_top_cgi(self, cgi_field: str):
        number = self.cgi_number.get().strip() or None
        date_from = self.cgi_date_from.get().strip() or None
        date_to = self.cgi_date_to.get().strip() or None
        limit = max(1, self._safe_int(self.cgi_limit.get(), 100))

        rows = self.db_manager.get_top_cgi(
            cgi_field=cgi_field,
            number=number,
            date_from=date_from,
            date_to=date_to,
            limit=limit,
        )

        target_tree = self.first_cgi_tree if cgi_field == "first_cgi" else self.last_cgi_tree
        for item in target_tree.get_children():
            target_tree.delete(item)
        for i, row in enumerate(rows, start=1):
            target_tree.insert("", tk.END, text=str(i), values=(row[0] or "", row[1] or 0))

        self.set_status(f"Top {cgi_field}: {len(rows)} rows")

    def run_numbers_on_cgi(self):
        cgi_value = self.cgi_value.get().strip()
        if not cgi_value:
            messagebox.showwarning("Missing input", "Please enter a CGI search value.")
            return
        limit = max(1, self._safe_int(self.cgi_numbers_limit.get(), 200))

        rows = self.db_manager.get_numbers_on_cgi(cgi_value, limit=limit)
        for item in self.cgi_numbers_tree.get_children():
            self.cgi_numbers_tree.delete(item)
        for i, row in enumerate(rows, start=1):
            self.cgi_numbers_tree.insert("", tk.END, text=str(i), values=(row[0] or "", row[1] or 0))
        self.set_status(f"CGI → Numbers: {len(rows)} rows")
    
    def change_database(self):
        """Change database file"""
        db_path = filedialog.asksaveasfilename(
            defaultextension=".db",
            filetypes=[("Database files", "*.db"), ("All files", "*.*")]
        )
        if db_path:
            self.db_path = db_path
            self.db_manager = DatabaseManager(db_path)
            messagebox.showinfo("Success", f"Database changed to: {db_path}")
            self.refresh_ui()
            self.view_all_records()


def main():
    """Main entry point"""
    root = tk.Tk()
    app = CDRAnalysisTool(root)
    root.mainloop()


if __name__ == "__main__":
    main()
