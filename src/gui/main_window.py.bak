    def create_database_tab(self):
        """Create database management tab"""
        frame = ttk.Frame(self.database_frame, padding="10")
        frame.pack(fill=tk.BOTH, expand=True)
        
        # Database controls
        control_frame = ttk.LabelFrame(frame, text="Database Management", padding="10")
        control_frame.pack(fill=tk.X, pady=10)
        
        ttk.Button(control_frame, text="Upload CSV File", 
                  command=self.upload_csv).pack(side=tk.LEFT, padx=5, pady=5)
        ttk.Button(control_frame, text="View All Records", command=self.view_all_records).pack(side=tk.LEFT, padx=5, pady=5)
        ttk.Button(control_frame, text="Clear Database", 
                  command=self.clear_database).pack(side=tk.LEFT, padx=5, pady=5)
        ttk.Button(control_frame, text="Export to CSV", 
                  command=self.export_to_csv).pack(side=tk.LEFT, padx=5, pady=5)

        self.db_limit_var = tk.StringVar(value="500")
        self.db_page_var = tk.StringVar(value="Page 1")
        self.db_total_var = tk.StringVar(value="0 records")

        ttk.Label(control_frame, text="Limit:").pack(side=tk.LEFT, padx=10)
        ttk.Entry(control_frame, width=8, textvariable=self.db_limit_var).pack(side=tk.LEFT)
        ttk.Label(control_frame, textvariable=self.db_page_var).pack(side=tk.LEFT, padx=10)
        ttk.Label(control_frame, textvariable=self.db_total_var).pack(side=tk.LEFT, padx=10)
        ttk.Button(control_frame, text="Prev", command=self.db_prev_page).pack(side=tk.LEFT, padx=5)
        ttk.Button(control_frame, text="Next", command=self.db_next_page).pack(side=tk.LEFT, padx=5)
        
        paned = ttk.PanedWindow(frame, orient=tk.HORIZONTAL)
        paned.pack(fill=tk.BOTH, expand=True, pady=5)

        table_frame = ttk.LabelFrame(paned, text="Database Records", padding="10")
        details_frame = ttk.LabelFrame(paned, text="Record Details", padding="10")
        paned.add(table_frame, weight=4)
        paned.add(details_frame, weight=2)

        vsb = ttk.Scrollbar(table_frame, orient=tk.VERTICAL)
        hsb = ttk.Scrollbar(table_frame, orient=tk.HORIZONTAL)

        self.db_tree = ttk.Treeview(
            table_frame,
            columns=(
                "A_PARTY",
                "B_PARTY",
