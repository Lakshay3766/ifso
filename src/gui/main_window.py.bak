        ttk.Label(controls, text="Date From:").grid(row=0, column=2, padx=5, pady=5, sticky=tk.W)
        self.rp_dur_date_from = ttk.Entry(controls, width=14)
        self.rp_dur_date_from.grid(row=0, column=3, padx=5, pady=5, sticky=tk.W)
        ttk.Label(controls, text="Date To:").grid(row=0, column=4, padx=5, pady=5, sticky=tk.W)
        self.rp_dur_date_to = ttk.Entry(controls, width=14)
        self.rp_dur_date_to.grid(row=0, column=5, padx=5, pady=5, sticky=tk.W)
        ttk.Label(controls, text="Limit:").grid(row=0, column=6, padx=5, pady=5, sticky=tk.W)
        self.rp_dur_limit = ttk.Entry(controls, width=8)
        self.rp_dur_limit.insert(0, "50")
        self.rp_dur_limit.grid(row=0, column=7, padx=5, pady=5, sticky=tk.W)
        ttk.Button(controls, text="Run", command=self.run_top_durations).grid(row=0, column=8, padx=5, pady=5, sticky=tk.W)
        ttk.Button(controls, text="Export", command=lambda: self.export_treeview_to_csv(self.top_duration_tree)).grid(row=0, column=9, padx=5, pady=5, sticky=tk.W)

        results = ttk.LabelFrame(duration_frame, text="Results", padding="10")
        results.pack(fill=tk.BOTH, expand=True, pady=5)
